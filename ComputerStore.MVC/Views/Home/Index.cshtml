@model IEnumerable<ComputerStore.MVC.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center mb-5 bg-dark text-white p-5 rounded">
    <h1 class="display-4 fw-bold">Chào mừng đến với Cửa hàng máy tính Nanh</h1>
    <p class="lead">Nơi cung cấp Laptop và PC Gaming hàng đầu!</p>
</div>

<div class="container">
    <h2 class="mb-4 border-bottom pb-2">Sản phẩm nổi bật</h2>

    <form method="get" asp-controller="Home" asp-action="Index" class="mb-4 bg-light p-3 rounded shadow-sm">
        <div class="row g-2">
            <div class="col-md-5">
                <input type="text" name="searchString" class="form-control" placeholder="Nhập tên máy tính cần tìm..." value="@Context.Request.Query["searchString"]" />
            </div>

            <div class="col-md-5">
                <select name="categoryId" class="form-select">
                    <option value="">-- Tất cả danh mục --</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.CategoryId" selected="@(Context.Request.Query["categoryId"] == cat.CategoryId.ToString() ? "selected" : null)">
                            @cat.CategoryId
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Tìm kiếm</button>
            </div>
        </div>
    </form>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm transition-hover">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.ProductName" style="height: 200px; object-fit: cover;">

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate" title="@item.ProductName">@item.ProductName</h5>

                        <p class="card-text text-danger fw-bold fs-5">
                            @String.Format("{0:0,0} VNĐ", item.Price)
                        </p>

                        <div class="mt-auto">
                            <a asp-controller="Home" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-outline-primary w-100 mb-2">Xem chi tiết</a>
                            <a href="#" class="btn btn-success w-100"><i class="bi bi-cart-plus"></i> Thêm vào giỏ</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .transition-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
        }
</style>
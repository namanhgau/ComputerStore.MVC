@model ComputerStore.MVC.Models.Product

@{
    ViewData["Title"] = Model.ProductName;
}

<div class="container mt-5">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary mb-4">
        <i class="bi bi-arrow-left"></i> Quay lại trang chủ
    </a>

    <div class="row">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <img src="@Model.ImageUrl" class="card-img-top img-fluid rounded" alt="@Model.ProductName" style="object-fit: contain; max-height: 400px;">
            </div>
        </div>

        <div class="col-md-7">
            <h2 class="fw-bold">@Model.ProductName</h2>
            <p class="badge bg-info text-dark fs-6">Danh mục: @Model.Category?.CategoryId</p>

            <h3 class="text-danger fw-bold mt-3">@String.Format("{0:0,0} VNĐ", Model.Price)</h3>

            <p class="mt-4">
                <strong>Tình trạng: </strong>
                @if (Model.StockQuantity > 0)
                {
                    <span class="text-success fw-bold">Còn hàng (@Model.StockQuantity chiếc)</span>
                }
                else
                {
                    <span class="text-danger fw-bold">Hết hàng</span>
                }
            </p>

            <div class="mt-4">
                <h5>Mô tả cấu hình:</h5>
                <p class="text-muted" style="white-space: pre-line;">@Model.Description</p>
            </div>

            <div class="mt-5">
                <button class="btn btn-success btn-lg px-5">
                    <i class="bi bi-cart-plus"></i> THÊM VÀO GIỎ HÀNG
                </button>
            </div>
        </div>
    </div>

    <div class="row mt-4 mb-5">

        <div class="col-md-6">
            <h4 class="mb-4">Đánh giá từ khách hàng</h4>

            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                // Sắp xếp bình luận mới nhất lên đầu
                foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                {
                    <div class="card mb-3 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="fw-bold mb-0 text-primary">@review.Username</h6>
                                <span class="text-warning">
                                    @for (int i = 0; i < review.Rating; i++)
                                    {
                                        <span>★</span>
                                    }
                                    @for (int i = review.Rating; i < 5; i++)
                                    {
                                        <span class="text-secondary">☆</span>
                                    }
                                </span>
                            </div>
                            <p class="text-muted" style="font-size: 0.85rem;">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                            <p class="card-text">@review.Comment</p>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này!</div>
            }
        </div>

        <div class="col-md-6">
            <h4 class="mb-4">Viết đánh giá của bạn</h4>
            <div class="card shadow-sm p-4 border-0 bg-light">
                <form asp-controller="Home" asp-action="AddReview" method="post">

                    <input type="hidden" name="productId" value="@Model.ProductId" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên của bạn:</label>
                        <input type="text" name="username" class="form-control" placeholder="Nhập tên..." required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Đánh giá sao:</label>
                        <select name="rating" class="form-select">
                            <option value="5">5 Sao - Cực kỳ hài lòng</option>
                            <option value="4">4 Sao - Rất tốt</option>
                            <option value="3">3 Sao - Bình thường</option>
                            <option value="2">2 Sao - Kém</option>
                            <option value="1">1 Sao - Rất tệ</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung đánh giá:</label>
                        <textarea name="comment" class="form-control" rows="4" placeholder="Chia sẻ cảm nhận của bạn về cấu hình, ngoại hình..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold">GỬI ĐÁNH GIÁ</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <h4>Đánh giá từ khách hàng</h4>
            <p class="text-muted">Tính năng bình luận sẽ sớm ra mắt...</p>
        </div>
    </div>
</div>